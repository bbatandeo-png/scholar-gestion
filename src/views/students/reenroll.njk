{% extends "layout.njk" %}
{% block content %}
  <section class="grid cols-2">
    <div class="panel">
      <h2>Reinscription de {{ student.lastname }} {{ student.firstname }}</h2>
      <form method="post" action="/students/{{ student._id }}/reenroll" class="stack">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <div class="form-grid">
          <label>Annee scolaire cible
            <select name="targetSchoolYearId" required>
              {% for year in schoolYears %}
                <option value="{{ year._id }}">{{ year.label }}</option>
              {% endfor %}
            </select>
          </label>
          <label>Niveau cible
            <select name="targetLevelId" required>
              {% for level in levels %}
                <option value="{{ level._id }}">{{ level.label }}</option>
              {% endfor %}
            </select>
          </label>
          <label>Motif
            <input name="reason" value="RETURNING_STUDENT" />
          </label>
          <label>Reporter les impayes
            <select name="carryOverArrears">
              <option value="true">Oui</option>
              <option value="false">Non</option>
            </select>
          </label>
        </div>
        <button type="submit">Valider la reinscription</button>
      </form>
    </div>
    <div class="panel">
      <h2>Impayes ouverts reportables</h2>
      <table>
        <thead><tr><th>Montant initial</th><th>Reste</th><th>Statut</th></tr></thead>
        <tbody>
          {% for item in openArrears %}
            <tr>
              <td>{{ item.amountInitial }}</td>
              <td>{{ item.amountRemaining }}</td>
              <td>{% set value = item.status %}{% include "partials/status-badge.njk" %}</td>
            </tr>
          {% else %}
            <tr><td colspan="3">Aucun impaye ouvert.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}