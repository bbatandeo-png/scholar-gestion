{% extends "layout.njk" %}
{% block content %}
  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2>Situation des paiements scolaires</h2>
        <p class="muted">L'inscription et l'écolage sont calculés et présentés séparément.</p>
      </div>
      <div class="panel-heading-actions">
        <a class="button secondary btn-icon icon-export" href="/reports/registration-paid/pdf?filter={{ filter }}{% if levelId %}&levelId={{ levelId }}{% endif %}{% if schoolYearId %}&schoolYearId={{ schoolYearId }}{% endif %}">Télécharger le PDF</a>
      </div>
    </div>

    <form method="get" action="/reports/registration-paid" class="toolbar-grid">
      <label>
        Type de paiement
        <select name="filter">
          <option value="registration" {% if filter == 'registration' %}selected{% endif %}>Inscription payée</option>
          <option value="tuition" {% if filter == 'tuition' %}selected{% endif %}>Écolage payé</option>
          <option value="partial" {% if filter == 'partial' %}selected{% endif %}>Paiement partiel</option>
          <option value="none" {% if filter == 'none' %}selected{% endif %}>Aucun paiement</option>
        </select>
      </label>
      <label>
        Classe
        <select name="levelId">
          <option value="" {% if not levelId %}selected{% endif %}>Toutes les classes</option>
          {% for level in levels %}
            <option value="{{ level._id }}" {% if levelId == level._id %}selected{% endif %}>{{ level.label }}</option>
          {% endfor %}
        </select>
      </label>
      <label>
        Année scolaire
        <select name="schoolYearId" required>
          {% for year in schoolYears %}
            <option value="{{ year._id }}" {% if schoolYearId == year._id %}selected{% endif %}>{{ year.label }}</option>
          {% endfor %}
        </select>
      </label>
      <button type="submit" class="button secondary">Appliquer</button>
    </form>

    <div class="report-document-heading">
      <strong>{{ schoolName | upper }}</strong>
      <span>
        {% if filter == 'tuition' %}
          Situation de paiement de l'écolage
        {% elif filter == 'partial' %}
          Situation des paiements partiels
        {% elif filter == 'none' %}
          Situation des élèves sans paiement
        {% else %}
          Situation de paiement des frais d'inscription
        {% endif %}
      </span>
      <b>Année scolaire : {{ schoolYearLabel }}</b>
    </div>

    <p class="muted">{{ report.length }} résultat(s). Cliquez sur un en-tête pour trier le tableau.</p>
    <div class="table-shell">
      <table class="table-report js-sortable payment-situation-table">
        <thead>
          <tr>
            <th class="sortable" data-column-index="0" data-sort-type="number">N°</th>
            <th class="sortable" data-column-index="1" data-sort-type="text">Nom et prénoms</th>
            <th class="sortable" data-column-index="2" data-sort-type="text">Sexe</th>
            <th class="sortable" data-column-index="3" data-sort-type="text">Matricule</th>
            <th class="sortable" data-column-index="4" data-sort-type="text">Classe</th>
            <th class="sortable" data-column-index="5" data-sort-type="number">Montant</th>
            <th class="sortable" data-column-index="6" data-sort-type="number">Payé</th>
            <th class="sortable" data-column-index="7" data-sort-type="number">Reste</th>
          </tr>
        </thead>
        <tbody>
          {% for item in report %}
            <tr>
              <td>{{ loop.index }}</td>
              <td>{{ item.enrollmentId.studentId.lastname if item.enrollmentId and item.enrollmentId.studentId }} {{ item.enrollmentId.studentId.firstname if item.enrollmentId and item.enrollmentId.studentId }}</td>
              <td>{{ item.enrollmentId.studentId.gender if item.enrollmentId and item.enrollmentId.studentId }}</td>
              <td>{{ item.enrollmentId.studentId.matricule if item.enrollmentId and item.enrollmentId.studentId }}</td>
              <td>{{ item.enrollmentId.levelId.label if item.enrollmentId and item.enrollmentId.levelId }}</td>
              <td>{{ item.amountDue }}</td>
              <td>{{ item.amountPaid }}</td>
              <td>{{ item.balanceDue }}</td>
            </tr>
          {% else %}
            <tr><td colspan="8">Aucun paiement trouvé pour ce filtre.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
