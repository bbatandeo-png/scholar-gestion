<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title or 'Scolar-Gestion' }}</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="sidebar-brand">
            <p class="eyebrow">Complexe scolaire</p>
            <h1>Scolar-Gestion</h1>
            <p class="sidebar-subtitle">Gestion administrative, scolaire et financière</p>
          </div>
          <button type="button" class="sidebar-toggle" aria-label="Afficher ou masquer le menu" aria-expanded="true">
            ☰
          </button>
        </div>
        <nav class="nav-links" aria-label="Navigation principale">
          {% set role = currentUser.role if currentUser else '' %}

          <div class="nav-group">
            <a href="/dashboard" class="nav-link {% if currentPath == '/dashboard' %}is-active{% endif %}">
              <span class="nav-icon">◈</span>
              <span>Tableau de bord</span>
            </a>
          </div>

          {% if role == 'super_admin' or role == 'direction' or role == 'secretariat' or role == 'auditeur' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and currentPath.startsWith('/students') %}open{% endif %}>
                <summary>Gestion scolaire</summary>
                <div class="nav-submenu">
                  <a href="/students" class="{% if currentPath and currentPath.startsWith('/students') and currentPath != '/students/search' %}is-active{% endif %}">Élèves</a>
                  <a href="/students/search" class="{% if currentPath == '/students/search' %}is-active{% endif %}">Recherche ancien élève</a>
                </div>
              </details>
            </div>
          {% endif %}

          {% if role == 'super_admin' or role == 'direction' or role == 'secretariat' or role == 'comptabilite' or role == 'auditeur' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and currentPath.startsWith('/enrollments') %}open{% endif %}>
                <summary>Admissions & paiements</summary>
                <div class="nav-submenu">
                  <a href="/enrollments" class="{% if currentPath and currentPath.startsWith('/enrollments') %}is-active{% endif %}">Inscriptions et paiements</a>
                </div>
              </details>
            </div>
          {% endif %}

          {% if role == 'super_admin' or role == 'direction' or role == 'comptabilite' or role == 'auditeur' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and (currentPath.startsWith('/expenses') or currentPath.startsWith('/arrears')) %}open{% endif %}>
                <summary>Finances</summary>
                <div class="nav-submenu">
                  {% if role == 'super_admin' or role == 'direction' or role == 'comptabilite' %}
                    <a href="/expenses" class="{% if currentPath and currentPath.startsWith('/expenses') %}is-active{% endif %}">Dépenses</a>
                  {% endif %}
                  <a href="/arrears" class="{% if currentPath and currentPath.startsWith('/arrears') %}is-active{% endif %}">Impayés</a>
                </div>
              </details>
            </div>
          {% endif %}

          {% if role == 'super_admin' or role == 'direction' or role == 'auditeur' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and currentPath.startsWith('/promotions') %}open{% endif %}>
                <summary>Organisation</summary>
                <div class="nav-submenu">
                  <a href="/promotions" class="{% if currentPath and currentPath.startsWith('/promotions') %}is-active{% endif %}">Promotions</a>
                </div>
              </details>
            </div>
          {% endif %}

          {% if role == 'super_admin' or role == 'direction' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and (currentPath.startsWith('/settings/school-years') or currentPath.startsWith('/settings/levels') or currentPath.startsWith('/settings/fees')) %}open{% endif %}>
                <summary>Paramètres</summary>
                <div class="nav-submenu">
                  <a href="/settings/school-years" class="{% if currentPath and currentPath.startsWith('/settings/school-years') %}is-active{% endif %}">Années scolaires</a>
                  <a href="/settings/levels" class="{% if currentPath and currentPath.startsWith('/settings/levels') %}is-active{% endif %}">Niveaux</a>
                  <a href="/settings/fees" class="{% if currentPath and currentPath.startsWith('/settings/fees') %}is-active{% endif %}">Frais</a>
                </div>
              </details>
            </div>
          {% endif %}

          {% if role == 'super_admin' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and currentPath.startsWith('/users') %}open{% endif %}>
                <summary>Administration</summary>
                <div class="nav-submenu">
                  <a href="/users" class="{% if currentPath and currentPath.startsWith('/users') %}is-active{% endif %}">Utilisateurs</a>
                </div>
              </details>
            </div>
          {% endif %}

          {% if role == 'comptabilite' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and currentPath.startsWith('/reports') %}open{% endif %}>
                <summary>Rapports & indicateurs</summary>
                <div class="nav-submenu">
                  <a href="/reports/revenue" class="{% if currentPath == '/reports/revenue' %}is-active{% endif %}">Rapports</a>
                  <a href="/reports/registration-paid" class="{% if currentPath and currentPath.startsWith('/reports/registration-paid') %}is-active{% endif %}">Inscriptions payées</a>
                </div>
              </details>
            </div>
          {% elif role == 'super_admin' or role == 'direction' or role == 'auditeur' %}
            <div class="nav-group">
              <details class="nav-details" {% if currentPath and currentPath.startsWith('/reports') %}open{% endif %}>
                <summary>Rapports & indicateurs</summary>
                <div class="nav-submenu">
                  <a href="/reports/students-by-level" class="{% if currentPath == '/reports/students-by-level' %}is-active{% endif %}">Rapports</a>
                  <a href="/reports/registration-paid" class="{% if currentPath and currentPath.startsWith('/reports/registration-paid') %}is-active{% endif %}">Inscriptions payées</a>
                </div>
              </details>
            </div>
          {% endif %}
        </nav>
      </aside>
      <main class="content">
        <header class="topbar">
          <div class="topbar-heading">
            <p class="eyebrow">Application administrative et financiere</p>
            <div class="topbar-title-row">
              {% if currentUser and currentPath and currentPath != '/dashboard' %}
                <button
                  type="button"
                  class="button secondary btn-sm btn-icon icon-prev"
                  onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href = '/dashboard'; }"
                >
                  Retour
                </button>
              {% endif %}
              <h2>{{ title or 'Scolar-Gestion' }}</h2>
            </div>
          </div>
          <div class="topbar-actions">
            {% if currentUser %}
              <span class="badge badge-neutral">{{ currentUser.role }}</span>
              <form action="/logout" method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                <button type="submit" class="button secondary">Deconnexion</button>
              </form>
            {% else %}
              <a href="/login" class="button">Connexion</a>
            {% endif %}
          </div>
        </header>

        {% if flash %}
          <div class="flash {{ flash.type }}">{{ flash.message }}</div>
        {% endif %}

        {% block content %}{% endblock %}
      </main>
    </div>
    <script>
      (() => {
        const sidebar = document.querySelector('.sidebar');
        const toggle = document.querySelector('.sidebar-toggle');
        const mediaQuery = window.matchMedia('(max-width: 980px)');

        const applySidebarState = () => {
          if (!sidebar || !toggle) {
            return;
          }

          if (mediaQuery.matches) {
            sidebar.classList.add('is-collapsed');
            sidebar.classList.remove('is-open');
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            sidebar.classList.remove('is-collapsed');
            sidebar.classList.add('is-open');
            toggle.setAttribute('aria-expanded', 'true');
          }
        };

        toggle?.addEventListener('click', () => {
          if (!mediaQuery.matches) {
            return;
          }

          const collapsed = sidebar.classList.toggle('is-collapsed');
          toggle.setAttribute('aria-expanded', String(!collapsed));
        });

        mediaQuery.addEventListener?.('change', applySidebarState);
        window.addEventListener('resize', applySidebarState);
        applySidebarState();

        const tables = document.querySelectorAll('table.js-sortable');

        tables.forEach((table) => {
          const body = table.querySelector('tbody');
          const headers = Array.from(table.querySelectorAll('th.sortable'));

          if (!body || headers.length === 0) {
            return;
          }

          headers.forEach((header) => {
            header.addEventListener('click', () => {
              const index = Number(header.dataset.columnIndex || '-1');
              const type = header.dataset.sortType || 'text';

              if (index < 0) {
                return;
              }

              const rows = Array.from(body.querySelectorAll('tr'));
              const current = header.dataset.sortDirection === 'asc' ? 'asc' : 'desc';
              const next = current === 'asc' ? 'desc' : 'asc';

              headers.forEach((th) => {
                th.classList.remove('sort-asc', 'sort-desc');
                th.dataset.sortDirection = '';
              });

              rows.sort((a, b) => {
                const aText = (a.children[index]?.textContent || '').trim();
                const bText = (b.children[index]?.textContent || '').trim();

                if (type === 'number') {
                  const aNum = Number(aText.replace(/[^0-9.-]/g, '')) || 0;
                  const bNum = Number(bText.replace(/[^0-9.-]/g, '')) || 0;
                  return next === 'asc' ? aNum - bNum : bNum - aNum;
                }

                return next === 'asc'
                  ? aText.localeCompare(bText, 'fr', { sensitivity: 'base' })
                  : bText.localeCompare(aText, 'fr', { sensitivity: 'base' });
              });

              rows.forEach((row) => body.appendChild(row));
              header.dataset.sortDirection = next;
              header.classList.add(next === 'asc' ? 'sort-asc' : 'sort-desc');
            });
          });
        });
      })();
    </script>
  </body>
</html>
