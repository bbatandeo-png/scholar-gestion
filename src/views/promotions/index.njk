{% extends "layout.njk" %}
{% block content %}
  <section class="panel">
    <h2>Preparation du passage annuel</h2>
    <form method="post" action="/promotions/prepare" class="stack">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <div class="form-grid">
        <label>Annee source
          <select name="sourceSchoolYearId">
            {% for year in schoolYears %}<option value="{{ year._id }}">{{ year.label }}</option>{% endfor %}
          </select>
        </label>
        <label>Annee cible
          <select name="targetSchoolYearId">
            {% for year in schoolYears %}<option value="{{ year._id }}">{{ year.label }}</option>{% endfor %}
          </select>
        </label>
      </div>
      <button type="submit" class="btn-icon icon-search">Preparer la liste</button>
    </form>

    <hr />

    <h3>Importer un fichier Excel des eleves admis</h3>
    <p>Colonnes attendues: matricule, decision, niveau_cible</p>
    <form method="post" action="/promotions/prepare-import?_csrf={{ csrfToken }}" enctype="multipart/form-data" class="stack">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <div class="form-grid">
        <label>Annee source
          <select name="sourceSchoolYearId">
            {% for year in schoolYears %}<option value="{{ year._id }}">{{ year.label }}</option>{% endfor %}
          </select>
        </label>
        <label>Annee cible
          <select name="targetSchoolYearId">
            {% for year in schoolYears %}<option value="{{ year._id }}">{{ year.label }}</option>{% endfor %}
          </select>
        </label>
      </div>
      <label>Fichier Excel (.xlsx)
        <input type="file" name="file" accept=".xlsx,.xls" required />
      </label>
      <button type="submit" class="secondary btn-icon icon-import">Importer et preparer</button>
    </form>
  </section>
{% endblock %}