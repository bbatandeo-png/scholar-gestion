{% extends "layout.njk" %}
{% block content %}
  <section class="grid cols-2">
    <div class="panel">
      <h2>Nouveau niveau</h2>
      <form method="post" action="/settings/levels" class="stack">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <div class="form-grid">
          <label>Code<input name="code" required /></label>
          <label>Libelle<input name="label" required /></label>
          <label>Ordre<input type="number" name="sortOrder" min="1" required /></label>
        </div>
        <button type="submit">Enregistrer</button>
      </form>
    </div>
    <div class="panel">
      <div class="panel-heading">
        <div>
          <h2>Niveaux</h2>
          <p class="muted">Export Excel pour la nomenclature des classes.</p>
        </div>
        <a class="button secondary" href="/settings/levels/export">Exporter Excel</a>
      </div>
      <table>
        <thead><tr><th>Code</th><th>Libelle</th><th>Ordre</th></tr></thead>
        <tbody>{% for item in levels %}<tr><td>{{ item.code }}</td><td>{{ item.label }}</td><td>{{ item.sortOrder }}</td></tr>{% endfor %}</tbody>
      </table>
    </div>
  </section>
{% endblock %}